{
  "expo": {
    "name": "TindaDone",
    "slug": "tindadone",
    "version": "1.0.0",
    "description": "TindaDone: The ultimate productivity and inventory manager for small businesses.",
    "githubUrl": "https://github.com/Carlwyne-Dev/TindaDone",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tindadone",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/loading.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F9F6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.carlwyne.tindadone"
    },
    "android": {
      "package": "com.carlwyne.tindadone",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "53224526-2727-480a-8153-f68714be3757"
      },
      "router": {}
    }
  }
}
